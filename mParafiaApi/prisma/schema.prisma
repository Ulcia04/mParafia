generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}


model Admin {
  id             Int          @id @default(autoincrement())
  login          String       @unique
  passwordHash   String
  isSuperAdmin   Boolean      @default(false)

  managedGroups  AdminGroup[]
}

model AdminGroup {
  adminId Int
  groupId Int

  admin   Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([adminId, groupId])
}


model Group {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  photoUrl    String?
  color       String?

  // Relacje odwrotne
  events      GroupEvent[]
  admins      AdminGroup[]
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  startTime   DateTime
  location    String?

  groups      GroupEvent[]
}

model GroupEvent {
  groupId Int
  eventId Int

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([groupId, eventId])
}


model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  date      DateTime
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id          Int      @id @default(autoincrement())
  content     String
  answer      String?
  author      String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model KancelariaItem {
  id          Int      @id @default(autoincrement())
  title       String
  photoUrl    String?
  content     String
  footer      String?
  files       Json?
}